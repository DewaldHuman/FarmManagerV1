# Copy to .env at the repo root. docker-compose.yml reads this file (env_file)
# for the api service, and interpolates ${VAR} references directly.

POSTGRES_USER=farm
POSTGRES_PASSWORD=farm
POSTGRES_DB=farm_platform

# MUST be overridden with a long random secret in any real deployment
# (staging/production/cloud) — docker-compose fails to start the api service
# if this is unset, by design (see docker-compose.yml).
JWT_SECRET=change_me_too

# 720 = 12 hours. Matches the LAN/low-risk deployment model — no refresh
# tokens in v1, users simply re-login after expiry.
JWT_EXPIRY_MINUTES=720
