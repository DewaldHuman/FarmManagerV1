@page "/irrigation/zones/{Id:guid}/design"
@layout AppShellLayout
@attribute [Authorize]
@using System.Globalization
@inject IFarmService FarmService
@inject IZoneDesignStore DesignStore
@inject NavigationManager Nav

@* Unlocalized by module-wide convention (see RunCalculator.razor / CLAUDE.md).
   This page is a thin adapter: interaction logic lives in Designer/ZoneDesignerSession,
   calculation logic in Designer/ZoneDesignEvaluator — both plain C#, unit-tested
   in Farm.Web.Irrigation.Tests. *@

<button class="calc-back-btn" @onclick="GoBack">← Zone overview</button>

@if (_loading)
{
    <p>Loading…</p>
}
else if (_zone is null)
{
    <p class="page-subtitle">Zone not found.</p>
}
else
{
    <div class="page-header">
        <div>
            <div class="app-shell__eyebrow">Zone design</div>
            <h1 class="app-shell__title">@_zone.Name</h1>
        </div>
        <div class="zone-designer-size">
            <label>Width (m)
                <input type="number" class="zone-designer-size__input" min="10" step="1"
                       @bind="_design.WidthMetres" @bind:after="MarkDirty" />
            </label>
            <label>Height (m)
                <input type="number" class="zone-designer-size__input" min="10" step="1"
                       @bind="_design.HeightMetres" @bind:after="MarkDirty" />
            </label>
        </div>
    </div>

    <div class="zone-designer-layout">
        <div>
            <div class="zone-designer-toolbar">
                <button class="zone-designer-tool @(ToolClass(DesignerTool.Select))" @onclick="() => SetToolAsync(DesignerTool.Select)">↖ Select</button>
                <button class="zone-designer-tool @(ToolClass(DesignerTool.Pipe))" @onclick="() => SetToolAsync(DesignerTool.Pipe)">— Draw pipe</button>
                <button class="zone-designer-tool @(ToolClass(DesignerTool.Pump))" @onclick="() => SetToolAsync(DesignerTool.Pump)">⚙ Pump</button>
                <button class="zone-designer-tool @(ToolClass(DesignerTool.Sprinkler))" @onclick="() => SetToolAsync(DesignerTool.Sprinkler)">✳ Sprinkler</button>
                <button class="zone-designer-tool @(ToolClass(DesignerTool.Valve))" @onclick="() => SetToolAsync(DesignerTool.Valve)">◆ Valve</button>
                <button class="zone-designer-tool @(ToolClass(DesignerTool.Source))" @onclick="() => SetToolAsync(DesignerTool.Source)">💧 Water source</button>
            </div>

            @if (_session.Tool == DesignerTool.Pipe)
            {
                <div class="zone-designer-hint">Click to place pipe points (horizontal/vertical runs, snapped to 1 m) — double-click to finish the pipe.</div>
            }

            <div class="zone-designer-canvas-wrap">
                <svg class="zone-designer-canvas @(_session.Tool == DesignerTool.Select ? "zone-designer-canvas--select" : "")"
                     width="@Px(_design.WidthMetres)" height="@Px(_design.HeightMetres)"
                     viewBox="0 0 @(S(_design.WidthMetres)) @(S(_design.HeightMetres))"
                     xmlns="http://www.w3.org/2000/svg">
                    <defs>
                        <pattern id="designGrid" width="5" height="5" patternUnits="userSpaceOnUse">
                            <path d="M 5 0 L 0 0 0 5" fill="none" stroke="#dfe3d2" stroke-width="0.12" />
                        </pattern>
                    </defs>

                    @* Background: fill + grid + border; the fill layer is the placement/deselect click target. *@
                    <rect x="0" y="0" width="@S(_design.WidthMetres)" height="@S(_design.HeightMetres)"
                          fill="#eef0e3" @onclick="OnCanvasClick" @ondblclick="OnCanvasDoubleClick" />
                    <rect x="0" y="0" width="@S(_design.WidthMetres)" height="@S(_design.HeightMetres)"
                          fill="url(#designGrid)" pointer-events="none" />
                    <rect x="0" y="0" width="@S(_design.WidthMetres)" height="@S(_design.HeightMetres)"
                          fill="none" stroke="#c9cdb9" stroke-width="1" vector-effect="non-scaling-stroke" pointer-events="none" />

                    @* Sprinkler coverage circles render behind everything else. *@
                    @foreach (var sprinkler in _design.Sprinklers)
                    {
                        <circle cx="@S(sprinkler.X)" cy="@S(sprinkler.Y)" r="@S(sprinkler.RadiusMetres ?? _design.Inputs.SprinklerRadiusMetres)"
                                fill="#2c6330" fill-opacity="0.06" stroke="#7ba57e" stroke-width="1"
                                stroke-dasharray="4 3" vector-effect="non-scaling-stroke" pointer-events="none" />
                    }

                    @foreach (var pipe in _design.Pipes)
                    {
                        var points = string.Join(" ", pipe.Vertices.Select(v => $"{S(v.X)},{S(v.Y)}"));
                        <g @onclick="() => _session.SelectElement(pipe)" @onclick:stopPropagation="true"
                           @onmousedown="() => _session.BeginDrag(pipe)" @onmousedown:preventDefault="true">
                            <polyline points="@points" fill="none" stroke="transparent" stroke-width="14" vector-effect="non-scaling-stroke" />
                            <polyline points="@points" fill="none"
                                      stroke="@(ReferenceEquals(_session.Selected, pipe) ? "#e07b26" : _eval.DisconnectedLateralIds.Contains(pipe.Id) ? "#d97706" : (pipe.IsMain ? "#2c6330" : "#4c8a50"))"
                                      stroke-width="@(pipe.IsMain ? 6 : 4)" stroke-linecap="round" stroke-linejoin="round"
                                      stroke-dasharray="@(_eval.DisconnectedLateralIds.Contains(pipe.Id) ? "8 5" : null)"
                                      vector-effect="non-scaling-stroke" />
                        </g>
                    }

                    @if (_session.DrawingPipe is not null && _session.DrawingPipe.Vertices.Count > 0)
                    {
                        var points = string.Join(" ", _session.DrawingPipe.Vertices.Select(v => $"{S(v.X)},{S(v.Y)}"));
                        <polyline points="@points" fill="none" stroke="#e07b26" stroke-width="4"
                                  stroke-dasharray="6 4" stroke-linecap="round" stroke-linejoin="round"
                                  vector-effect="non-scaling-stroke" pointer-events="none" />
                        @foreach (var v in _session.DrawingPipe.Vertices)
                        {
                            <circle cx="@S(v.X)" cy="@S(v.Y)" r="0.6" fill="#e07b26" pointer-events="none" />
                        }
                    }

                    @foreach (var sprinkler in _design.Sprinklers)
                    {
                        <g @onclick="() => _session.SelectElement(sprinkler)" @onclick:stopPropagation="true"
                           @onmousedown="() => _session.BeginDrag(sprinkler)" @onmousedown:preventDefault="true">
                            <circle cx="@S(sprinkler.X)" cy="@S(sprinkler.Y)" r="1.6" fill="transparent" />
                            <circle cx="@S(sprinkler.X)" cy="@S(sprinkler.Y)" r="0.6"
                                    fill="@(ReferenceEquals(_session.Selected, sprinkler) ? "#e07b26" : _eval.FarSprinklerIds.Contains(sprinkler.Id) ? "#d97706" : "#2c6330")" />
                        </g>
                    }

                    @foreach (var point in _design.Points)
                    {
                        <g @onclick="() => _session.SelectElement(point)" @onclick:stopPropagation="true"
                           @onmousedown="() => _session.BeginDrag(point)" @onmousedown:preventDefault="true">
                            <circle cx="@S(point.X)" cy="@S(point.Y)" r="2.2" fill="transparent" />
                            @if (point.Kind == DesignPointKind.Pump)
                            {
                                <rect x="@S(point.X - 1.2)" y="@S(point.Y - 1.2)" width="2.4" height="2.4" rx="0.5"
                                      fill="@(ReferenceEquals(_session.Selected, point) ? "#e07b26" : "#18361a")" />
                            }
                            else if (point.Kind == DesignPointKind.WaterSource)
                            {
                                <circle cx="@S(point.X)" cy="@S(point.Y)" r="1.2"
                                        fill="@(ReferenceEquals(_session.Selected, point) ? "#e07b26" : "#2b6cb0")" />
                            }
                            else
                            {
                                <rect x="@S(point.X - 0.9)" y="@S(point.Y - 0.9)" width="1.8" height="1.8"
                                      transform="rotate(45 @S(point.X) @S(point.Y))"
                                      fill="@(ReferenceEquals(_session.Selected, point) ? "#e07b26" : "#6e4d32")" />
                            }
                        </g>
                    }

                    @if (_session.Selected is DesignPipe handlePipe && _session.Tool == DesignerTool.Select && handlePipe.Vertices.Count >= 2)
                    {
                        @* Endpoint resize handles for the selected pipe. *@
                        var hFirst = handlePipe.Vertices[0];
                        var hLast = handlePipe.Vertices[^1];
                        <circle cx="@S(hFirst.X)" cy="@S(hFirst.Y)" r="0.9" fill="#fff" stroke="#e07b26" stroke-width="2"
                                vector-effect="non-scaling-stroke"
                                style="cursor: @(hFirst.Y == handlePipe.Vertices[1].Y ? "ew-resize" : "ns-resize");"
                                @onmousedown="() => _session.BeginVertexDrag(handlePipe, false)"
                                @onmousedown:preventDefault="true" @onmousedown:stopPropagation="true" />
                        <circle cx="@S(hLast.X)" cy="@S(hLast.Y)" r="0.9" fill="#fff" stroke="#e07b26" stroke-width="2"
                                vector-effect="non-scaling-stroke"
                                style="cursor: @(hLast.Y == handlePipe.Vertices[^2].Y ? "ew-resize" : "ns-resize");"
                                @onmousedown="() => _session.BeginVertexDrag(handlePipe, true)"
                                @onmousedown:preventDefault="true" @onmousedown:stopPropagation="true" />
                    }

                    @if (_session.IsDragging)
                    {
                        @* Full-canvas drag overlay: keeps OffsetX/Y in SVG space during the move. *@
                        <rect x="0" y="0" width="@S(_design.WidthMetres)" height="@S(_design.HeightMetres)"
                              fill="transparent" style="cursor: grabbing;"
                              @onmousemove="OnDragMove" @onmouseup="OnDragEnd" @onmouseleave="OnDragEnd" />
                    }
                </svg>

                @if (_design.IsEmpty && _session.DrawingPipe is null)
                {
                    <div class="zone-designer-empty">
                        No layout yet — use the toolbar to draw pipes and place your pump, sprinklers and valves.
                    </div>
                }
            </div>
        </div>

        <div class="zone-designer-panel">
            <div class="card zone-designer-save">
                <div class="zone-designer-save__status">
                    @if (_dirty)
                    {
                        <span class="zone-designer-save__dot"></span>
                        <span>Unsaved changes</span>
                    }
                    else if (_lastSavedAt is not null)
                    {
                        <span>Saved @_lastSavedAt.Value.ToLocalTime().ToString("dd/MM HH:mm", CultureInfo.InvariantCulture)</span>
                    }
                    else
                    {
                        <span>New design — not saved yet</span>
                    }
                </div>
                <div class="zone-designer-save__actions">
                    <input class="zone-designer-input__field zone-designer-save__name" placeholder="Version name (optional)" @bind="_saveName" />
                    <button class="btn btn-primary zone-designer-save__btn" @onclick="SaveVersionAsync" disabled="@_saving">Save</button>
                    @if (_dirty)
                    {
                        <button class="btn btn-secondary zone-designer-save__btn" @onclick="DiscardAsync">Discard</button>
                    }
                </div>
                @if (_saveFailed)
                {
                    <div class="zone-designer-save__error">Save failed — try again.</div>
                }
                @if (_versions.Count > 0)
                {
                    <button class="zone-designer-inspector__reset" @onclick="() => _showHistory = !_showHistory">
                        @(_showHistory ? "Hide history" : $"History ({_versions.Count})")
                    </button>
                    @if (_showHistory)
                    {
                        <div class="zone-designer-versions">
                            @foreach (var version in _versions)
                            {
                                <div class="zone-designer-versions__row @(version.Id == _loadedVersionId ? "zone-designer-versions__row--current" : "")">
                                    <span>@(string.IsNullOrEmpty(version.Name) ? "Unnamed" : version.Name) · @version.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm", CultureInfo.InvariantCulture)</span>
                                    <button class="zone-designer-inspector__reset" @onclick="() => LoadVersionAsync(version.Id)">Load</button>
                                </div>
                            }
                        </div>
                    }
                }
            </div>

            @if (_session.Selected is not null)
            {
                <div class="card zone-designer-inspector">
                    <div class="zone-designer-inspector__header">
                        <span class="zone-designer-inspector__title">@SelectedTitle()</span>
                        <button class="zone-designer-inspector__close" title="Clear selection" @onclick="_session.ClearSelection">✕</button>
                    </div>
                    @foreach (var (label, value) in SelectedSpecs())
                    {
                        <div class="zone-designer-inspector__row">
                            <span>@label</span>
                            <strong>@value</strong>
                        </div>
                    }
                    @foreach (var prop in SelectedEditableProps())
                    {
                        <div class="zone-designer-inspector__row zone-designer-inspector__row--edit">
                            <span>@prop.Label</span>
                            <span class="zone-designer-inspector__edit">
                                <input type="number" class="zone-designer-input__field" step="any"
                                       value="@S(prop.Get())"
                                       @onchange="e => OnPropChanged(prop, e)" />
                                <span class="zone-designer-input__unit">@prop.Unit</span>
                            </span>
                        </div>
                    }
                    @if (_session.Selected is DesignPipe inspectedPipe)
                    {
                        <button class="zone-designer-inspector__promote" @onclick="TogglePipeMainAsync">
                            @(inspectedPipe.IsMain ? "Make this a lateral" : "Make main pipe")
                        </button>
                    }
                    @if (SelectedHasOverrides())
                    {
                        <button class="zone-designer-inspector__reset" @onclick="ResetSelectedOverridesAsync">Reset to design defaults</button>
                    }
                    <button class="btn btn-secondary zone-designer-inspector__remove" @onclick="RemoveSelectedAsync">Remove</button>
                </div>
            }

            <div class="zone-designer-solver">
                <div class="zone-designer-solver__label">@SolverLabel()</div>
                <div class="zone-designer-solver__value">@SolverValue()</div>
                <div class="zone-designer-solver__note">@SolverNote()</div>
            </div>

            <label class="zone-designer-solve-for">Solve for
                <select class="calc-select" @bind="_solveMode">
                    <option value="@SolveMode.Runtime">Runtime (from target depth)</option>
                    <option value="@SolveMode.PumpFlow">Required pump flow</option>
                    <option value="@SolveMode.MaxSprinklers">Max sprinklers this pump supports</option>
                </select>
            </label>

            @if (_eval.Warnings.Count > 0)
            {
                <div class="zone-designer-warnings">
                    @foreach (var warning in _eval.Warnings)
                    {
                        <div class="zone-designer-warnings__item">⚠ @warning</div>
                    }
                </div>
            }

            <div class="zone-designer-section">Design inputs</div>
            @foreach (var input in _inputRows)
            {
                (bool Disabled, string? Note) status = input.Status?.Invoke() ?? (false, null);
                <div class="zone-designer-input">
                    <label>@input.Label</label>
                    <span>
                        <input type="number" class="zone-designer-input__field" step="any"
                               disabled="@status.Disabled"
                               value="@(status.Disabled && input.CanvasValue is not null ? input.CanvasValue() : S(input.Get()))"
                               @onchange="e => OnInputChanged(input, e)" />
                        <span class="zone-designer-input__unit">@(status.Note ?? input.Unit)</span>
                    </span>
                </div>
            }

            <div class="zone-designer-section">Results</div>
            @if (_eval.Results is null)
            {
                <p class="zone-designer-result__sub">Enter valid (positive) design inputs to see results.</p>
            }
            else
            {
                var results = _eval.Results;
                <div class="zone-designer-result">
                    <div>
                        <div>Total demand flow</div>
                        <div class="zone-designer-result__sub">@results.EffectiveSprinklerCount sprinklers@(results.CountFromCanvas ? " placed on canvas" : "") × @F0(results.AvgSprinklerFlowLitresPerHour) L/hr</div>
                    </div>
                    <strong>@F0(results.DemandFlowLitresPerMinute) L/min</strong>
                </div>
                <div class="zone-designer-result">
                    <div>
                        <div>Main pipe velocity</div>
                        <div class="zone-designer-result__sub">@VelocityNote(results.MainVelocity)</div>
                    </div>
                    <strong>@F2(results.MainVelocity) m/s</strong>
                </div>
                <div class="zone-designer-result">
                    <div>
                        <div>Lateral pipe velocity</div>
                        <div class="zone-designer-result__sub">@VelocityNote(results.LateralVelocity)@(results.LateralCountAssumed ? " · assumes 3 laterals (none drawn)" : results.BusiestLateralSprinklers > 0 ? $" · busiest lateral: {results.BusiestLateralSprinklers} sprinklers" : "")</div>
                    </div>
                    <strong>@F2(results.LateralVelocity) m/s</strong>
                </div>
                <div class="zone-designer-result">
                    <div>
                        <div>Friction loss (main + lateral)</div>
                        <div class="zone-designer-result__sub">Hazen-Williams + Christiansen, C=150</div>
                    </div>
                    <strong>@F2(results.FrictionLossBar) bar</strong>
                </div>
                <div class="zone-designer-result">
                    <div>
                        <div>Required pump pressure</div>
                        <div class="zone-designer-result__sub">incl. 2.0 bar at sprinkler head</div>
                    </div>
                    <strong>@F1(results.RequiredPumpPressureBar) bar</strong>
                </div>
                <div class="zone-designer-result">
                    <div>
                        <div>Sprinkler coverage</div>
                        <div class="zone-designer-result__sub">@CoverageNote(results.CoverageRatio)</div>
                    </div>
                    <strong>@F2(results.CoverageRatio)× radius/spacing</strong>
                </div>
                <div class="zone-designer-result">
                    <div>
                        <div>Application rate</div>
                        <div class="zone-designer-result__sub">@(results.SpacingFromCanvas ? $"avg canvas spacing {F1(results.EffectiveSpacingMetres)} m" : $"from spacing {F0(_design.Inputs.SprinklerSpacingMetres)}m")</div>
                    </div>
                    <strong>@F1(results.ApplicationRateMmPerHour) mm/hr</strong>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private const double PxPerMetre = 9;

    private enum SolveMode { Runtime, PumpFlow, MaxSprinklers }

    private ZoneDto? _zone;
    private bool _loading = true;
    private SolveMode _solveMode = SolveMode.Runtime;

    private readonly ZoneDesignerSession _session = new();
    private DesignEvaluation _eval = ZoneDesignEvaluator.Evaluate(new ZoneDesign());

    // Save/versions state: edits stay local (playground) until an explicit Save
    // creates a new immutable version; Discard reloads the latest saved one.
    private bool _dirty;
    private bool _saving;
    private bool _saveFailed;
    private bool _showHistory;
    private string _saveName = "";
    private DateTimeOffset? _lastSavedAt;
    private Guid? _loadedVersionId;
    private List<DesignVersionInfo> _versions = new();

    private ZoneDesign _design => _session.Design;

    // Status lets a global input reflect per-element overrides on the canvas:
    // disabled with a note when fully taken over, a "k of n custom" note when
    // partial. CanvasValue supplies the displayed value while disabled (e.g. the
    // placed count, or the layout's derived spacing).
    private sealed record InputRow(
        string Label, string Unit, Func<double> Get, Action<double> Set,
        Func<(bool Disabled, string? Note)>? Status = null, Func<string>? CanvasValue = null);

    private List<InputRow> _inputRows = new();

    protected override async Task OnInitializedAsync()
    {
        _zone = await FarmService.GetZoneAsync(Id);
        if (_zone is not null)
        {
            _session.Design = await DesignStore.GetLatestAsync(Id) ?? new ZoneDesign();
            _versions = await DesignStore.ListVersionsAsync(Id);
            _lastSavedAt = _versions.FirstOrDefault()?.CreatedAt;
            _loadedVersionId = _versions.FirstOrDefault()?.Id;
        }

        (bool Disabled, string? Note) GroupStatus(int overridden, int total) =>
            total == 0 || overridden == 0 ? (false, null)
            : overridden == total ? (true, "set on canvas")
            : (false, $"{overridden} of {total} custom");

        // Note: lambdas read _design.Inputs dynamically (not a captured instance)
        // so Load/Discard swapping the working design keeps the rows live.
        _inputRows = new List<InputRow>
        {
            new("Pump flow", "L/min", () => _design.Inputs.PumpFlowLitresPerMinute, v => _design.Inputs.PumpFlowLitresPerMinute = v,
                Status: () => _design.Points.FirstOrDefault(p => p.Kind == DesignPointKind.Pump)?.RatedFlowLitresPerMinute is not null
                    ? (true, "set on pump") : (false, null)),
            new("Pump pressure", "bar", () => _design.Inputs.PumpPressureBar, v => _design.Inputs.PumpPressureBar = v,
                Status: () => _design.Points.FirstOrDefault(p => p.Kind == DesignPointKind.Pump)?.RatedPressureBar is not null
                    ? (true, "set on pump") : (false, null)),
            new("Main pipe diameter", "mm", () => _design.Inputs.MainDiameterMm, v => _design.Inputs.MainDiameterMm = v,
                Status: () => _design.Pipes.FirstOrDefault(p => p.IsMain)?.DiameterMm is not null
                    ? (true, "set on canvas") : (false, null)),
            new("Lateral pipe diameter", "mm", () => _design.Inputs.LateralDiameterMm, v => _design.Inputs.LateralDiameterMm = v,
                Status: () => GroupStatus(_design.Pipes.Count(p => !p.IsMain && p.DiameterMm is not null), _design.Pipes.Count(p => !p.IsMain))),
            new("Sprinkler count", "", () => _design.Inputs.SprinklerCount, v => _design.Inputs.SprinklerCount = (int)v,
                Status: () => _design.Sprinklers.Count > 0 ? (true, "from canvas") : (false, null),
                CanvasValue: () => _design.Sprinklers.Count.ToString(CultureInfo.InvariantCulture)),
            new("Sprinkler flow (each)", "L/hr", () => _design.Inputs.SprinklerFlowLitresPerHour, v => _design.Inputs.SprinklerFlowLitresPerHour = v,
                Status: () => GroupStatus(_design.Sprinklers.Count(s => s.FlowLitresPerHour is not null), _design.Sprinklers.Count)),
            new("Sprinkler spacing", "m", () => _design.Inputs.SprinklerSpacingMetres, v => _design.Inputs.SprinklerSpacingMetres = v,
                Status: () => _design.Sprinklers.Count >= 2 ? (true, "from canvas") : (false, null),
                CanvasValue: () => F1(_eval.Results?.EffectiveSpacingMetres ?? _design.Inputs.SprinklerSpacingMetres)),
            new("Sprinkler radius", "m", () => _design.Inputs.SprinklerRadiusMetres, v => _design.Inputs.SprinklerRadiusMetres = v,
                Status: () => GroupStatus(_design.Sprinklers.Count(s => s.RadiusMetres is not null), _design.Sprinklers.Count)),
            new("Target depth", "mm", () => _design.Inputs.TargetDepthMm, v => _design.Inputs.TargetDepthMm = v),
        };

        Recompute();
        _loading = false;
    }

    private void GoBack() => Nav.NavigateTo($"/irrigation/zones/{Id}");

    private void Recompute() => _eval = ZoneDesignEvaluator.Evaluate(_design);

    // Edits are local-only (playground); persistence happens on explicit Save.
    private void MarkDirty()
    {
        Recompute();
        _dirty = true;
    }

    private void MarkDirtyIfChanged(bool changed)
    {
        if (changed)
        {
            MarkDirty();
        }
    }

    private async Task SaveVersionAsync()
    {
        _saving = true;
        _saveFailed = false;
        var info = await DesignStore.SaveVersionAsync(Id, _design, _saveName);
        _saving = false;
        if (info is null)
        {
            _saveFailed = true;
            return;
        }

        _versions.Insert(0, info);
        _loadedVersionId = info.Id;
        _lastSavedAt = info.CreatedAt;
        _dirty = false;
        _saveName = "";
    }

    private async Task DiscardAsync()
    {
        _session.Design = await DesignStore.GetLatestAsync(Id) ?? new ZoneDesign();
        _session.ClearSelection();
        _loadedVersionId = _versions.FirstOrDefault()?.Id;
        _dirty = false;
        Recompute();
    }

    private async Task LoadVersionAsync(Guid designId)
    {
        var design = await DesignStore.GetVersionAsync(designId);
        if (design is null)
        {
            return;
        }

        _session.Design = design;
        _session.ClearSelection();
        _loadedVersionId = designId;
        // Loading anything but the latest is a working copy — restore by saving.
        _dirty = designId != _versions.FirstOrDefault()?.Id;
        Recompute();
    }

    // ---- Pointer adapters (pixels → metres → session) ----

    private string ToolClass(DesignerTool tool) => _session.Tool == tool ? "zone-designer-tool--active" : "";

    private void SetToolAsync(DesignerTool tool) => MarkDirtyIfChanged(_session.SetTool(tool));

    private void OnCanvasClick(MouseEventArgs e) =>
        MarkDirtyIfChanged(_session.CanvasClick(e.OffsetX / PxPerMetre, e.OffsetY / PxPerMetre));

    private void OnCanvasDoubleClick(MouseEventArgs e) => MarkDirtyIfChanged(_session.CanvasDoubleClick());

    private void OnDragMove(MouseEventArgs e) => _session.DragMove(e.OffsetX / PxPerMetre, e.OffsetY / PxPerMetre);

    private void OnDragEnd() => MarkDirtyIfChanged(_session.DragEnd());

    private void RemoveSelectedAsync() => MarkDirtyIfChanged(_session.RemoveSelected());

    private void TogglePipeMainAsync() => MarkDirtyIfChanged(_session.TogglePipeMain());

    // ---- Inspector ----

    private string SelectedTitle() => _session.Selected switch
    {
        DesignPipe pipe => pipe.IsMain ? "Main pipe" : "Lateral pipe",
        DesignSprinkler => "Sprinkler",
        DesignPoint point => point.Kind switch
        {
            DesignPointKind.Pump => "Pump",
            DesignPointKind.WaterSource => "Water source",
            _ => "Valve",
        },
        _ => "",
    };

    private List<(string Label, string Value)> SelectedSpecs()
    {
        var inputs = _design.Inputs;
        switch (_session.Selected)
        {
            case DesignPipe pipe:
            {
                if (!pipe.IsMain && _eval.LateralStats.TryGetValue(pipe.Id, out var stats))
                {
                    var rows = new List<(string, string)>
                    {
                        ("Length", $"{F1(pipe.LengthMetres)} m"),
                        ("Sprinklers", stats.SprinklerCount.ToString()),
                        ("Flow", $"{F1(stats.FlowLitresPerMinute)} L/min"),
                        ("Velocity", $"{F2(stats.Velocity)} m/s"),
                    };
                    if (_eval.DisconnectedLateralIds.Contains(pipe.Id))
                    {
                        rows.Insert(0, ("Connected", "No — carries no flow"));
                    }

                    return rows;
                }

                var flow = pipe.IsMain ? _eval.Results?.DemandFlowLitresPerMinute : _eval.Results?.LateralFlowLitresPerMinute;
                var velocity = pipe.IsMain ? _eval.Results?.MainVelocity : _eval.Results?.LateralVelocity;
                return new()
                {
                    ("Length", $"{F1(pipe.LengthMetres)} m"),
                    ("Flow", flow is null ? "—" : $"{F1(flow.Value)} L/min"),
                    ("Velocity", velocity is null ? "—" : $"{F2(velocity.Value)} m/s"),
                };
            }
            case DesignSprinkler:
                return new()
                {
                    ("Spacing", $"{F1(_eval.Results?.EffectiveSpacingMetres ?? inputs.SprinklerSpacingMetres)} m"),
                };
            case DesignPoint point when point.Kind == DesignPointKind.Pump:
                return new();
            case DesignPoint point:
                return new()
                {
                    ("Position", $"{F0(point.X)}, {F0(point.Y)} m"),
                };
            default:
                return new();
        }
    }

    // ---- Per-element property overrides (null = inherit the design input) ----

    private sealed record EditableProp(string Label, string Unit, Func<double> Get, Action<double> Set, Action Clear);

    private List<EditableProp> SelectedEditableProps()
    {
        var i = _design.Inputs;
        return _session.Selected switch
        {
            DesignSprinkler s => new()
            {
                new("Flow", "L/hr", () => s.FlowLitresPerHour ?? i.SprinklerFlowLitresPerHour, v => s.FlowLitresPerHour = v, () => s.FlowLitresPerHour = null),
                new("Radius", "m", () => s.RadiusMetres ?? i.SprinklerRadiusMetres, v => s.RadiusMetres = v, () => s.RadiusMetres = null),
            },
            DesignPipe p => new()
            {
                new("Diameter", "mm", () => p.DiameterMm ?? (p.IsMain ? i.MainDiameterMm : i.LateralDiameterMm), v => p.DiameterMm = v, () => p.DiameterMm = null),
            },
            DesignPoint pt when pt.Kind == DesignPointKind.Pump => new()
            {
                new("Rated flow", "L/min", () => pt.RatedFlowLitresPerMinute ?? i.PumpFlowLitresPerMinute, v => pt.RatedFlowLitresPerMinute = v, () => pt.RatedFlowLitresPerMinute = null),
                new("Rated pressure", "bar", () => pt.RatedPressureBar ?? i.PumpPressureBar, v => pt.RatedPressureBar = v, () => pt.RatedPressureBar = null),
            },
            _ => new(),
        };
    }

    private void OnPropChanged(EditableProp prop, ChangeEventArgs e)
    {
        if (double.TryParse(e.Value as string, NumberStyles.Float, CultureInfo.InvariantCulture, out var value) && value > 0)
        {
            prop.Set(value);
        }
        else
        {
            // Invalid or non-positive entry clears the override — the re-render
            // snaps the field back to the inherited design-input value.
            prop.Clear();
        }

        MarkDirty();
    }

    private bool SelectedHasOverrides() => _session.Selected switch
    {
        DesignSprinkler s => s.FlowLitresPerHour is not null || s.RadiusMetres is not null,
        DesignPipe p => p.DiameterMm is not null,
        DesignPoint pt => pt.RatedFlowLitresPerMinute is not null || pt.RatedPressureBar is not null,
        _ => false,
    };

    private void ResetSelectedOverridesAsync()
    {
        switch (_session.Selected)
        {
            case DesignSprinkler s:
                s.FlowLitresPerHour = null;
                s.RadiusMetres = null;
                break;
            case DesignPipe p:
                p.DiameterMm = null;
                break;
            case DesignPoint pt:
                pt.RatedFlowLitresPerMinute = null;
                pt.RatedPressureBar = null;
                break;
        }

        MarkDirty();
    }

    private void OnInputChanged(InputRow input, ChangeEventArgs e)
    {
        if (double.TryParse(e.Value as string, NumberStyles.Float, CultureInfo.InvariantCulture, out var value))
        {
            input.Set(value);
            MarkDirty();
        }
    }

    // ---- Solver / formatting ----

    private string SolverLabel() => _solveMode switch
    {
        SolveMode.PumpFlow => "REQUIRED PUMP FLOW",
        SolveMode.MaxSprinklers => "MAX SPRINKLERS SUPPORTED",
        _ => "RECOMMENDED RUNTIME",
    };

    private string SolverValue()
    {
        if (_eval.Results is null)
        {
            return "—";
        }

        return _solveMode switch
        {
            SolveMode.PumpFlow => $"{F0(_eval.Results.DemandFlowLitresPerMinute)} L/min",
            SolveMode.MaxSprinklers => $"{_eval.Results.MaxSprinklers}",
            _ => $"{F0(_eval.Results.RunTimeMinutes)} min",
        };
    }

    private string SolverNote()
    {
        if (_eval.Results is null)
        {
            return "Enter valid design inputs";
        }

        var i = _design.Inputs;
        return _solveMode switch
        {
            SolveMode.PumpFlow => $"{_eval.Results.EffectiveSprinklerCount} sprinklers{(_eval.Results.CountFromCanvas ? " placed on canvas" : "")} × {F0(_eval.Results.AvgSprinklerFlowLitresPerHour)} L/hr",
            SolveMode.MaxSprinklers => $"at {F0(_eval.Results.PumpFlowLitresPerMinute)} L/min pump flow, {F0(i.SprinklerFlowLitresPerHour)} L/hr each",
            _ => $"to deliver {F0(i.TargetDepthMm)}mm at {F1(_eval.Results.ApplicationRateMmPerHour)} mm/hr",
        };
    }

    private static string VelocityNote(double velocity) =>
        velocity <= 1.5 ? "Within recommended range" : "Above ~1.5 m/s guideline";

    private static string CoverageNote(double ratio)
    {
        // Note: relational switch patterns ("< 0.9 =>") break the Razor parser
        // inside @code blocks (misread as a tag) — hence plain ifs here.
        if (ratio < 0.9)
        {
            return "Gaps in coverage — increase radius or reduce spacing";
        }

        if (ratio > 1.3)
        {
            return "Heavy overlap — spacing could be wider";
        }

        return "Good coverage";
    }

    private static string Px(double metres) => (metres * PxPerMetre).ToString("0", CultureInfo.InvariantCulture);
    private static string S(double value) => value.ToString("0.###", CultureInfo.InvariantCulture);
    private static string F0(double value) => value.ToString("0", CultureInfo.InvariantCulture);
    private static string F1(double value) => value.ToString("0.0", CultureInfo.InvariantCulture);
    private static string F2(double value) => value.ToString("0.00", CultureInfo.InvariantCulture);
}
