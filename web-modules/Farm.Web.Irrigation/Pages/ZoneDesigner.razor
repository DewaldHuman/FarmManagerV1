@page "/irrigation/zones/{Id:guid}/design"
@layout AppShellLayout
@attribute [Authorize]
@using System.Globalization
@inject IFarmService FarmService
@inject IZoneDesignStore DesignStore
@inject NavigationManager Nav

@* Unlocalized by module-wide convention (see RunCalculator.razor / CLAUDE.md). *@

<button class="calc-back-btn" @onclick="GoBack">← Zone overview</button>

@if (_loading)
{
    <p>Loading…</p>
}
else if (_zone is null)
{
    <p class="page-subtitle">Zone not found.</p>
}
else
{
    <div class="page-header">
        <div>
            <div class="app-shell__eyebrow">Zone design</div>
            <h1 class="app-shell__title">@_zone.Name</h1>
        </div>
        <div class="zone-designer-size">
            <label>Width (m)
                <input type="number" class="zone-designer-size__input" min="10" step="1"
                       @bind="_design.WidthMetres" @bind:after="SaveDesignAsync" />
            </label>
            <label>Height (m)
                <input type="number" class="zone-designer-size__input" min="10" step="1"
                       @bind="_design.HeightMetres" @bind:after="SaveDesignAsync" />
            </label>
        </div>
    </div>

    <div class="zone-designer-layout">
        <div>
            <div class="zone-designer-toolbar">
                <button class="zone-designer-tool @(ToolClass(Tool.Select))" @onclick="() => SetTool(Tool.Select)">↖ Select</button>
                <button class="zone-designer-tool @(ToolClass(Tool.Pipe))" @onclick="() => SetTool(Tool.Pipe)">— Draw pipe</button>
                <button class="zone-designer-tool @(ToolClass(Tool.Pump))" @onclick="() => SetTool(Tool.Pump)">⚙ Pump</button>
                <button class="zone-designer-tool @(ToolClass(Tool.Sprinkler))" @onclick="() => SetTool(Tool.Sprinkler)">✳ Sprinkler</button>
                <button class="zone-designer-tool @(ToolClass(Tool.Valve))" @onclick="() => SetTool(Tool.Valve)">◆ Valve</button>
                <button class="zone-designer-tool @(ToolClass(Tool.Source))" @onclick="() => SetTool(Tool.Source)">💧 Water source</button>
            </div>

            @if (_tool == Tool.Pipe)
            {
                <div class="zone-designer-hint">Click to place pipe points (horizontal/vertical runs, snapped to 1 m) — double-click to finish the pipe.</div>
            }

            <div class="zone-designer-canvas-wrap">
                <svg class="zone-designer-canvas @(_tool == Tool.Select ? "zone-designer-canvas--select" : "")"
                     width="@Px(_design.WidthMetres)" height="@Px(_design.HeightMetres)"
                     viewBox="0 0 @(S(_design.WidthMetres)) @(S(_design.HeightMetres))"
                     xmlns="http://www.w3.org/2000/svg">
                    <defs>
                        <pattern id="designGrid" width="5" height="5" patternUnits="userSpaceOnUse">
                            <path d="M 5 0 L 0 0 0 5" fill="none" stroke="#dfe3d2" stroke-width="0.12" />
                        </pattern>
                    </defs>

                    @* Background: fill + grid + border; the fill layer is the placement/deselect click target. *@
                    <rect x="0" y="0" width="@S(_design.WidthMetres)" height="@S(_design.HeightMetres)"
                          fill="#eef0e3" @onclick="OnCanvasClick" @ondblclick="OnCanvasDoubleClick" />
                    <rect x="0" y="0" width="@S(_design.WidthMetres)" height="@S(_design.HeightMetres)"
                          fill="url(#designGrid)" pointer-events="none" />
                    <rect x="0" y="0" width="@S(_design.WidthMetres)" height="@S(_design.HeightMetres)"
                          fill="none" stroke="#c9cdb9" stroke-width="1" vector-effect="non-scaling-stroke" pointer-events="none" />

                    @* Sprinkler coverage circles render behind everything else. *@
                    @foreach (var sprinkler in _design.Sprinklers)
                    {
                        <circle cx="@S(sprinkler.X)" cy="@S(sprinkler.Y)" r="@S(sprinkler.RadiusMetres ?? _design.Inputs.SprinklerRadiusMetres)"
                                fill="#2c6330" fill-opacity="0.06" stroke="#7ba57e" stroke-width="1"
                                stroke-dasharray="4 3" vector-effect="non-scaling-stroke" pointer-events="none" />
                    }

                    @foreach (var pipe in _design.Pipes)
                    {
                        var points = string.Join(" ", pipe.Vertices.Select(v => $"{S(v.X)},{S(v.Y)}"));
                        <g @onclick="() => SelectElement(pipe)" @onclick:stopPropagation="true"
                           @onmousedown="() => BeginDrag(pipe)" @onmousedown:preventDefault="true">
                            <polyline points="@points" fill="none" stroke="transparent" stroke-width="14" vector-effect="non-scaling-stroke" />
                            <polyline points="@points" fill="none"
                                      stroke="@(ReferenceEquals(_selected, pipe) ? "#e07b26" : _disconnectedLateralIds.Contains(pipe.Id) ? "#d97706" : (pipe.IsMain ? "#2c6330" : "#4c8a50"))"
                                      stroke-width="@(pipe.IsMain ? 6 : 4)" stroke-linecap="round" stroke-linejoin="round"
                                      stroke-dasharray="@(_disconnectedLateralIds.Contains(pipe.Id) ? "8 5" : null)"
                                      vector-effect="non-scaling-stroke" />
                        </g>
                    }

                    @if (_drawingPipe is not null && _drawingPipe.Vertices.Count > 0)
                    {
                        var points = string.Join(" ", _drawingPipe.Vertices.Select(v => $"{S(v.X)},{S(v.Y)}"));
                        <polyline points="@points" fill="none" stroke="#e07b26" stroke-width="4"
                                  stroke-dasharray="6 4" stroke-linecap="round" stroke-linejoin="round"
                                  vector-effect="non-scaling-stroke" pointer-events="none" />
                        @foreach (var v in _drawingPipe.Vertices)
                        {
                            <circle cx="@S(v.X)" cy="@S(v.Y)" r="0.6" fill="#e07b26" pointer-events="none" />
                        }
                    }

                    @foreach (var sprinkler in _design.Sprinklers)
                    {
                        <g @onclick="() => SelectElement(sprinkler)" @onclick:stopPropagation="true"
                           @onmousedown="() => BeginDrag(sprinkler)" @onmousedown:preventDefault="true">
                            <circle cx="@S(sprinkler.X)" cy="@S(sprinkler.Y)" r="1.6" fill="transparent" />
                            <circle cx="@S(sprinkler.X)" cy="@S(sprinkler.Y)" r="0.6"
                                    fill="@(ReferenceEquals(_selected, sprinkler) ? "#e07b26" : _farSprinklerIds.Contains(sprinkler.Id) ? "#d97706" : "#2c6330")" />
                        </g>
                    }

                    @foreach (var point in _design.Points)
                    {
                        <g @onclick="() => SelectElement(point)" @onclick:stopPropagation="true"
                           @onmousedown="() => BeginDrag(point)" @onmousedown:preventDefault="true">
                            <circle cx="@S(point.X)" cy="@S(point.Y)" r="2.2" fill="transparent" />
                            @if (point.Kind == DesignPointKind.Pump)
                            {
                                <rect x="@S(point.X - 1.2)" y="@S(point.Y - 1.2)" width="2.4" height="2.4" rx="0.5"
                                      fill="@(ReferenceEquals(_selected, point) ? "#e07b26" : "#18361a")" />
                            }
                            else if (point.Kind == DesignPointKind.WaterSource)
                            {
                                <circle cx="@S(point.X)" cy="@S(point.Y)" r="1.2"
                                        fill="@(ReferenceEquals(_selected, point) ? "#e07b26" : "#2b6cb0")" />
                            }
                            else
                            {
                                <rect x="@S(point.X - 0.9)" y="@S(point.Y - 0.9)" width="1.8" height="1.8"
                                      transform="rotate(45 @S(point.X) @S(point.Y))"
                                      fill="@(ReferenceEquals(_selected, point) ? "#e07b26" : "#6e4d32")" />
                            }
                        </g>
                    }

                    @if (_selected is DesignPipe handlePipe && _tool == Tool.Select && handlePipe.Vertices.Count >= 2)
                    {
                        @* Endpoint resize handles for the selected pipe. *@
                        var hFirst = handlePipe.Vertices[0];
                        var hLast = handlePipe.Vertices[^1];
                        <circle cx="@S(hFirst.X)" cy="@S(hFirst.Y)" r="0.9" fill="#fff" stroke="#e07b26" stroke-width="2"
                                vector-effect="non-scaling-stroke"
                                style="cursor: @(hFirst.Y == handlePipe.Vertices[1].Y ? "ew-resize" : "ns-resize");"
                                @onmousedown="() => BeginVertexDrag(handlePipe, false)"
                                @onmousedown:preventDefault="true" @onmousedown:stopPropagation="true" />
                        <circle cx="@S(hLast.X)" cy="@S(hLast.Y)" r="0.9" fill="#fff" stroke="#e07b26" stroke-width="2"
                                vector-effect="non-scaling-stroke"
                                style="cursor: @(hLast.Y == handlePipe.Vertices[^2].Y ? "ew-resize" : "ns-resize");"
                                @onmousedown="() => BeginVertexDrag(handlePipe, true)"
                                @onmousedown:preventDefault="true" @onmousedown:stopPropagation="true" />
                    }

                    @if (_dragTarget is not null)
                    {
                        @* Full-canvas drag overlay: keeps OffsetX/Y in SVG space during the move. *@
                        <rect x="0" y="0" width="@S(_design.WidthMetres)" height="@S(_design.HeightMetres)"
                              fill="transparent" style="cursor: grabbing;"
                              @onmousemove="OnDragMove" @onmouseup="OnDragEnd" @onmouseleave="OnDragEnd" />
                    }
                </svg>

                @if (_design.IsEmpty && _drawingPipe is null)
                {
                    <div class="zone-designer-empty">
                        No layout yet — use the toolbar to draw pipes and place your pump, sprinklers and valves.
                    </div>
                }
            </div>
        </div>

        <div class="zone-designer-panel">
            @if (_selected is not null)
            {
                <div class="card zone-designer-inspector">
                    <div class="zone-designer-inspector__header">
                        <span class="zone-designer-inspector__title">@SelectedTitle()</span>
                        <button class="zone-designer-inspector__close" title="Clear selection" @onclick="ClearSelection">✕</button>
                    </div>
                    @foreach (var (label, value) in SelectedSpecs())
                    {
                        <div class="zone-designer-inspector__row">
                            <span>@label</span>
                            <strong>@value</strong>
                        </div>
                    }
                    @foreach (var prop in SelectedEditableProps())
                    {
                        <div class="zone-designer-inspector__row zone-designer-inspector__row--edit">
                            <span>@prop.Label</span>
                            <span class="zone-designer-inspector__edit">
                                <input type="number" class="zone-designer-input__field" step="any"
                                       value="@S(prop.Get())"
                                       @onchange="e => OnPropChanged(prop, e)" />
                                <span class="zone-designer-input__unit">@prop.Unit</span>
                            </span>
                        </div>
                    }
                    @if (_selected is DesignPipe inspectedPipe)
                    {
                        <button class="zone-designer-inspector__promote" @onclick="TogglePipeMainAsync">
                            @(inspectedPipe.IsMain ? "Make this a lateral" : "Make main pipe")
                        </button>
                    }
                    @if (SelectedHasOverrides())
                    {
                        <button class="zone-designer-inspector__reset" @onclick="ResetSelectedOverridesAsync">Reset to design defaults</button>
                    }
                    <button class="btn btn-secondary zone-designer-inspector__remove" @onclick="RemoveSelectedAsync">Remove</button>
                </div>
            }

            <div class="zone-designer-solver">
                <div class="zone-designer-solver__label">@SolverLabel()</div>
                <div class="zone-designer-solver__value">@SolverValue()</div>
                <div class="zone-designer-solver__note">@SolverNote()</div>
            </div>

            <label class="zone-designer-solve-for">Solve for
                <select class="calc-select" @bind="_solveMode">
                    <option value="@SolveMode.Runtime">Runtime (from target depth)</option>
                    <option value="@SolveMode.PumpFlow">Required pump flow</option>
                    <option value="@SolveMode.MaxSprinklers">Max sprinklers this pump supports</option>
                </select>
            </label>

            @if (_warnings.Count > 0)
            {
                <div class="zone-designer-warnings">
                    @foreach (var warning in _warnings)
                    {
                        <div class="zone-designer-warnings__item">⚠ @warning</div>
                    }
                </div>
            }

            <div class="zone-designer-section">Design inputs</div>
            @foreach (var input in _inputRows)
            {
                (bool Disabled, string? Note) status = input.Status?.Invoke() ?? (false, null);
                <div class="zone-designer-input">
                    <label>@input.Label</label>
                    <span>
                        <input type="number" class="zone-designer-input__field" step="any"
                               disabled="@status.Disabled"
                               value="@(status.Disabled && input.CanvasValue is not null ? input.CanvasValue() : S(input.Get()))"
                               @onchange="e => OnInputChanged(input, e)" />
                        <span class="zone-designer-input__unit">@(status.Note ?? input.Unit)</span>
                    </span>
                </div>
            }

            <div class="zone-designer-section">Results</div>
            @if (_results is null)
            {
                <p class="zone-designer-result__sub">Enter valid (positive) design inputs to see results.</p>
            }
            else
            {
                <div class="zone-designer-result">
                    <div>
                        <div>Total demand flow</div>
                        <div class="zone-designer-result__sub">@_results.EffectiveSprinklerCount sprinklers@(_results.CountFromCanvas ? " placed on canvas" : "") × @F0(_results.AvgSprinklerFlowLitresPerHour) L/hr</div>
                    </div>
                    <strong>@F0(_results.DemandFlowLitresPerMinute) L/min</strong>
                </div>
                <div class="zone-designer-result">
                    <div>
                        <div>Main pipe velocity</div>
                        <div class="zone-designer-result__sub">@VelocityNote(_results.MainVelocity)</div>
                    </div>
                    <strong>@F2(_results.MainVelocity) m/s</strong>
                </div>
                <div class="zone-designer-result">
                    <div>
                        <div>Lateral pipe velocity</div>
                        <div class="zone-designer-result__sub">@VelocityNote(_results.LateralVelocity)@(_results.LateralCountAssumed ? " · assumes 3 laterals (none drawn)" : _results.BusiestLateralSprinklers > 0 ? $" · busiest lateral: {_results.BusiestLateralSprinklers} sprinklers" : "")</div>
                    </div>
                    <strong>@F2(_results.LateralVelocity) m/s</strong>
                </div>
                <div class="zone-designer-result">
                    <div>
                        <div>Friction loss (main + lateral)</div>
                        <div class="zone-designer-result__sub">Hazen-Williams + Christiansen, C=150</div>
                    </div>
                    <strong>@F2(_results.FrictionLossBar) bar</strong>
                </div>
                <div class="zone-designer-result">
                    <div>
                        <div>Required pump pressure</div>
                        <div class="zone-designer-result__sub">incl. 2.0 bar at sprinkler head</div>
                    </div>
                    <strong>@F1(_results.RequiredPumpPressureBar) bar</strong>
                </div>
                <div class="zone-designer-result">
                    <div>
                        <div>Sprinkler coverage</div>
                        <div class="zone-designer-result__sub">@CoverageNote(_results.CoverageRatio)</div>
                    </div>
                    <strong>@F2(_results.CoverageRatio)× radius/spacing</strong>
                </div>
                <div class="zone-designer-result">
                    <div>
                        <div>Application rate</div>
                        <div class="zone-designer-result__sub">@(_results.SpacingFromCanvas ? $"avg canvas spacing {F1(_results.EffectiveSpacingMetres)} m" : $"from spacing {F0(_design.Inputs.SprinklerSpacingMetres)}m")</div>
                    </div>
                    <strong>@F1(_results.ApplicationRateMmPerHour) mm/hr</strong>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private const double PxPerMetre = 9;

    private enum Tool { Select, Pipe, Pump, Sprinkler, Valve, Source }

    private enum SolveMode { Runtime, PumpFlow, MaxSprinklers }

    private ZoneDto? _zone;
    private ZoneDesign _design = new();
    private bool _loading = true;

    private Tool _tool = Tool.Select;
    private SolveMode _solveMode = SolveMode.Runtime;
    private DesignPipe? _drawingPipe;
    private object? _selected;

    // Drag-to-move (Select tool). While dragging, a transparent overlay rect
    // covers the whole canvas so MouseEventArgs.OffsetX/Y stays in SVG space
    // no matter which element is under the cursor (offset is target-relative).
    private object? _dragTarget;
    private bool _dragStarted;
    private double _dragGrabDx, _dragGrabDy; // sprinkler/point: element pos − pointer pos
    private double _pipeAnchorX, _pipeAnchorY; // pipe: last applied (snapped) pointer

    // Endpoint resize: non-null switches the drag into vertex mode — the endpoint
    // slides along its adjacent segment's axis (straight/90° runs preserved).
    private DesignVertex? _dragVertex;
    private DesignVertex? _dragVertexNeighbor;

    private DesignResults? _results;

    // Status lets a global input reflect per-element overrides on the canvas:
    // disabled with a note when fully taken over, a "k of n custom" note when
    // partial. CanvasValue supplies the displayed value while disabled (e.g. the
    // placed count, or the layout's derived spacing).
    private sealed record InputRow(
        string Label, string Unit, Func<double> Get, Action<double> Set,
        Func<(bool Disabled, string? Note)>? Status = null, Func<string>? CanvasValue = null);

    private List<InputRow> _inputRows = new();

    protected override async Task OnInitializedAsync()
    {
        _zone = await FarmService.GetZoneAsync(Id);
        if (_zone is not null)
        {
            _design = await DesignStore.GetAsync(Id) ?? new ZoneDesign();
        }

        var inputs = _design.Inputs;

        (bool Disabled, string? Note) GroupStatus(int overridden, int total) =>
            total == 0 || overridden == 0 ? (false, null)
            : overridden == total ? (true, "set on canvas")
            : (false, $"{overridden} of {total} custom");

        _inputRows = new List<InputRow>
        {
            new("Pump flow", "L/min", () => inputs.PumpFlowLitresPerMinute, v => inputs.PumpFlowLitresPerMinute = v,
                Status: () => _design.Points.FirstOrDefault(p => p.Kind == DesignPointKind.Pump)?.RatedFlowLitresPerMinute is not null
                    ? (true, "set on pump") : (false, null)),
            new("Pump pressure", "bar", () => inputs.PumpPressureBar, v => inputs.PumpPressureBar = v,
                Status: () => _design.Points.FirstOrDefault(p => p.Kind == DesignPointKind.Pump)?.RatedPressureBar is not null
                    ? (true, "set on pump") : (false, null)),
            new("Main pipe diameter", "mm", () => inputs.MainDiameterMm, v => inputs.MainDiameterMm = v,
                Status: () => _design.Pipes.FirstOrDefault(p => p.IsMain)?.DiameterMm is not null
                    ? (true, "set on canvas") : (false, null)),
            new("Lateral pipe diameter", "mm", () => inputs.LateralDiameterMm, v => inputs.LateralDiameterMm = v,
                Status: () => GroupStatus(_design.Pipes.Count(p => !p.IsMain && p.DiameterMm is not null), _design.Pipes.Count(p => !p.IsMain))),
            new("Sprinkler count", "", () => inputs.SprinklerCount, v => inputs.SprinklerCount = (int)v,
                Status: () => _design.Sprinklers.Count > 0 ? (true, "from canvas") : (false, null),
                CanvasValue: () => _design.Sprinklers.Count.ToString(CultureInfo.InvariantCulture)),
            new("Sprinkler flow (each)", "L/hr", () => inputs.SprinklerFlowLitresPerHour, v => inputs.SprinklerFlowLitresPerHour = v,
                Status: () => GroupStatus(_design.Sprinklers.Count(s => s.FlowLitresPerHour is not null), _design.Sprinklers.Count)),
            new("Sprinkler spacing", "m", () => inputs.SprinklerSpacingMetres, v => inputs.SprinklerSpacingMetres = v,
                Status: () => _design.Sprinklers.Count >= 2 ? (true, "from canvas") : (false, null),
                CanvasValue: () => F1(_results?.EffectiveSpacingMetres ?? inputs.SprinklerSpacingMetres)),
            new("Sprinkler radius", "m", () => inputs.SprinklerRadiusMetres, v => inputs.SprinklerRadiusMetres = v,
                Status: () => GroupStatus(_design.Sprinklers.Count(s => s.RadiusMetres is not null), _design.Sprinklers.Count)),
            new("Target depth", "mm", () => inputs.TargetDepthMm, v => inputs.TargetDepthMm = v),
        };

        Recompute();
        _loading = false;
    }

    private void GoBack() => Nav.NavigateTo($"/irrigation/zones/{Id}");

    private async Task OnInputChanged(InputRow input, ChangeEventArgs e)
    {
        if (double.TryParse(e.Value as string, NumberStyles.Float, CultureInfo.InvariantCulture, out var value))
        {
            input.Set(value);
            await SaveDesignAsync();
        }
    }

    // ---- Tools & canvas ----

    private string ToolClass(Tool tool) => _tool == tool ? "zone-designer-tool--active" : "";

    private async Task SetTool(Tool tool)
    {
        if (_tool == Tool.Pipe && tool != Tool.Pipe)
        {
            await FinishPipeAsync();
        }

        _tool = tool;
    }

    private static string Px(double metres) => (metres * PxPerMetre).ToString("0", CultureInfo.InvariantCulture);

    private static string S(double value) => value.ToString("0.###", CultureInfo.InvariantCulture);

    private (double X, double Y) SnapFromClick(MouseEventArgs e)
    {
        var x = Math.Clamp(Math.Round(e.OffsetX / PxPerMetre), 0, _design.WidthMetres);
        var y = Math.Clamp(Math.Round(e.OffsetY / PxPerMetre), 0, _design.HeightMetres);
        return (x, y);
    }

    // ---- Drag-to-move ----

    private void BeginDrag(object element)
    {
        if (_tool != Tool.Select)
        {
            return;
        }

        _selected = element;
        _dragTarget = element;
        _dragStarted = false;
    }

    private void BeginVertexDrag(DesignPipe pipe, bool endVertex)
    {
        if (_tool != Tool.Select || pipe.Vertices.Count < 2)
        {
            return;
        }

        _selected = pipe;
        _dragTarget = pipe; // renders the drag overlay
        _dragVertex = endVertex ? pipe.Vertices[^1] : pipe.Vertices[0];
        _dragVertexNeighbor = endVertex ? pipe.Vertices[^2] : pipe.Vertices[1];
    }

    private void OnDragMove(MouseEventArgs e)
    {
        if (_dragTarget is null)
        {
            return;
        }

        var px = e.OffsetX / PxPerMetre;
        var py = e.OffsetY / PxPerMetre;

        if (_dragVertex is not null && _dragVertexNeighbor is not null)
        {
            // Endpoint resize: slide along the adjacent segment's axis only,
            // never landing on the neighbor (min 1 m segment).
            var (sx, sy) = SnapClamp(px, py);
            if (_dragVertex.Y == _dragVertexNeighbor.Y)
            {
                if (sx != _dragVertexNeighbor.X)
                {
                    _dragVertex.X = sx;
                }
            }
            else if (sy != _dragVertexNeighbor.Y)
            {
                _dragVertex.Y = sy;
            }

            return;
        }

        if (!_dragStarted)
        {
            // First move: record grab offsets so the element doesn't jump under the pointer.
            switch (_dragTarget)
            {
                case DesignSprinkler s:
                    _dragGrabDx = s.X - px;
                    _dragGrabDy = s.Y - py;
                    break;
                case DesignPoint p:
                    _dragGrabDx = p.X - px;
                    _dragGrabDy = p.Y - py;
                    break;
                case DesignPipe:
                    _pipeAnchorX = Math.Round(px);
                    _pipeAnchorY = Math.Round(py);
                    break;
            }

            _dragStarted = true;
            return;
        }

        switch (_dragTarget)
        {
            case DesignSprinkler s:
                (s.X, s.Y) = SnapClamp(px + _dragGrabDx, py + _dragGrabDy);
                break;
            case DesignPoint p:
                (p.X, p.Y) = SnapClamp(px + _dragGrabDx, py + _dragGrabDy);
                break;
            case DesignPipe pipe:
                var dx = Math.Round(px) - _pipeAnchorX;
                var dy = Math.Round(py) - _pipeAnchorY;
                if (dx != 0 || dy != 0)
                {
                    // Clamp the translation so no vertex leaves the canvas.
                    dx = Math.Clamp(dx, -pipe.Vertices.Min(v => v.X), _design.WidthMetres - pipe.Vertices.Max(v => v.X));
                    dy = Math.Clamp(dy, -pipe.Vertices.Min(v => v.Y), _design.HeightMetres - pipe.Vertices.Max(v => v.Y));
                    foreach (var v in pipe.Vertices)
                    {
                        v.X += dx;
                        v.Y += dy;
                    }

                    _pipeAnchorX += dx;
                    _pipeAnchorY += dy;
                }
                break;
        }
    }

    private async Task OnDragEnd()
    {
        if (_dragTarget is null)
        {
            return;
        }

        _dragTarget = null;
        _dragVertex = null;
        _dragVertexNeighbor = null;
        await SaveDesignAsync(); // recompute once on drop (sprinkler→lateral assignment may change)
    }

    private (double X, double Y) SnapClamp(double x, double y) =>
        (Math.Clamp(Math.Round(x), 0, _design.WidthMetres), Math.Clamp(Math.Round(y), 0, _design.HeightMetres));

    private async Task OnCanvasClick(MouseEventArgs e)
    {
        var (x, y) = SnapFromClick(e);
        switch (_tool)
        {
            case Tool.Select:
                _selected = null;
                break;
            case Tool.Pipe:
                AddPipeVertex(x, y);
                break;
            case Tool.Pump:
                await AddPointAsync(DesignPointKind.Pump, x, y);
                break;
            case Tool.Sprinkler:
                _design.Sprinklers.Add(new DesignSprinkler { X = x, Y = y });
                await SaveDesignAsync();
                break;
            case Tool.Valve:
                await AddPointAsync(DesignPointKind.Valve, x, y);
                break;
            case Tool.Source:
                await AddPointAsync(DesignPointKind.WaterSource, x, y);
                break;
        }
    }

    private async Task OnCanvasDoubleClick(MouseEventArgs e)
    {
        if (_tool == Tool.Pipe)
        {
            await FinishPipeAsync();
        }
    }

    private void AddPipeVertex(double x, double y)
    {
        _drawingPipe ??= new DesignPipe();
        if (_drawingPipe.Vertices.Count > 0)
        {
            // Straight/90° segments only: constrain to the dominant axis.
            var last = _drawingPipe.Vertices[^1];
            if (Math.Abs(x - last.X) >= Math.Abs(y - last.Y))
            {
                y = last.Y;
            }
            else
            {
                x = last.X;
            }

            if (x == last.X && y == last.Y)
            {
                return; // duplicate click (the first half of a double-click lands here too)
            }
        }

        _drawingPipe.Vertices.Add(new DesignVertex { X = x, Y = y });
    }

    private async Task FinishPipeAsync()
    {
        if (_drawingPipe is not null && _drawingPipe.Vertices.Count >= 2)
        {
            // First pipe drawn becomes the main line; later pipes are laterals.
            _drawingPipe.IsMain = !_design.Pipes.Any(p => p.IsMain);
            _design.Pipes.Add(_drawingPipe);
            _drawingPipe = null;
            await SaveDesignAsync();
        }
        else
        {
            _drawingPipe = null;
        }
    }

    private async Task AddPointAsync(DesignPointKind kind, double x, double y)
    {
        _design.Points.Add(new DesignPoint { Kind = kind, X = x, Y = y });
        await SaveDesignAsync();
    }

    private async Task SaveDesignAsync()
    {
        Recompute();
        await DesignStore.SaveAsync(Id, _design);
    }

    // ---- Selection / inspector ----

    private void SelectElement(object element)
    {
        if (_tool == Tool.Select)
        {
            _selected = element;
        }
    }

    private void ClearSelection() => _selected = null;

    private async Task RemoveSelectedAsync()
    {
        switch (_selected)
        {
            case DesignPipe pipe:
                _design.Pipes.Remove(pipe);
                break;
            case DesignSprinkler sprinkler:
                _design.Sprinklers.Remove(sprinkler);
                break;
            case DesignPoint point:
                _design.Points.Remove(point);
                break;
        }

        _selected = null;
        await SaveDesignAsync();
    }

    private string SelectedTitle() => _selected switch
    {
        DesignPipe pipe => pipe.IsMain ? "Main pipe" : "Lateral pipe",
        DesignSprinkler => "Sprinkler",
        DesignPoint point => point.Kind switch
        {
            DesignPointKind.Pump => "Pump",
            DesignPointKind.WaterSource => "Water source",
            _ => "Valve",
        },
        _ => "",
    };

    private List<(string Label, string Value)> SelectedSpecs()
    {
        var inputs = _design.Inputs;
        switch (_selected)
        {
            case DesignPipe pipe:
            {
                if (!pipe.IsMain && _lateralStats.TryGetValue(pipe.Id, out var stats))
                {
                    var rows = new List<(string, string)>
                    {
                        ("Length", $"{F1(pipe.LengthMetres)} m"),
                        ("Sprinklers", stats.SprinklerCount.ToString()),
                        ("Flow", $"{F1(stats.FlowLitresPerMinute)} L/min"),
                        ("Velocity", $"{F2(stats.Velocity)} m/s"),
                    };
                    if (_disconnectedLateralIds.Contains(pipe.Id))
                    {
                        rows.Insert(0, ("Connected", "No — carries no flow"));
                    }

                    return rows;
                }

                var flow = pipe.IsMain ? _results?.DemandFlowLitresPerMinute : _results?.LateralFlowLitresPerMinute;
                var velocity = pipe.IsMain ? _results?.MainVelocity : _results?.LateralVelocity;
                return new()
                {
                    ("Length", $"{F1(pipe.LengthMetres)} m"),
                    ("Flow", flow is null ? "—" : $"{F1(flow.Value)} L/min"),
                    ("Velocity", velocity is null ? "—" : $"{F2(velocity.Value)} m/s"),
                };
            }
            case DesignSprinkler:
                return new()
                {
                    ("Spacing", $"{F1(_results?.EffectiveSpacingMetres ?? inputs.SprinklerSpacingMetres)} m"),
                };
            case DesignPoint point when point.Kind == DesignPointKind.Pump:
                return new();
            case DesignPoint point:
                return new()
                {
                    ("Position", $"{F0(point.X)}, {F0(point.Y)} m"),
                };
            default:
                return new();
        }
    }

    // ---- Per-element property overrides (null = inherit the design input) ----

    private sealed record EditableProp(string Label, string Unit, Func<double> Get, Action<double> Set, Action Clear);

    private List<EditableProp> SelectedEditableProps()
    {
        var i = _design.Inputs;
        return _selected switch
        {
            DesignSprinkler s => new()
            {
                new("Flow", "L/hr", () => s.FlowLitresPerHour ?? i.SprinklerFlowLitresPerHour, v => s.FlowLitresPerHour = v, () => s.FlowLitresPerHour = null),
                new("Radius", "m", () => s.RadiusMetres ?? i.SprinklerRadiusMetres, v => s.RadiusMetres = v, () => s.RadiusMetres = null),
            },
            DesignPipe p => new()
            {
                new("Diameter", "mm", () => p.DiameterMm ?? (p.IsMain ? i.MainDiameterMm : i.LateralDiameterMm), v => p.DiameterMm = v, () => p.DiameterMm = null),
            },
            DesignPoint pt when pt.Kind == DesignPointKind.Pump => new()
            {
                new("Rated flow", "L/min", () => pt.RatedFlowLitresPerMinute ?? i.PumpFlowLitresPerMinute, v => pt.RatedFlowLitresPerMinute = v, () => pt.RatedFlowLitresPerMinute = null),
                new("Rated pressure", "bar", () => pt.RatedPressureBar ?? i.PumpPressureBar, v => pt.RatedPressureBar = v, () => pt.RatedPressureBar = null),
            },
            _ => new(),
        };
    }

    private async Task OnPropChanged(EditableProp prop, ChangeEventArgs e)
    {
        if (double.TryParse(e.Value as string, NumberStyles.Float, CultureInfo.InvariantCulture, out var value) && value > 0)
        {
            prop.Set(value);
        }
        else
        {
            // Invalid or non-positive entry clears the override — the re-render
            // snaps the field back to the inherited design-input value.
            prop.Clear();
        }

        await SaveDesignAsync();
    }

    private bool SelectedHasOverrides() => _selected switch
    {
        DesignSprinkler s => s.FlowLitresPerHour is not null || s.RadiusMetres is not null,
        DesignPipe p => p.DiameterMm is not null,
        DesignPoint pt => pt.RatedFlowLitresPerMinute is not null || pt.RatedPressureBar is not null,
        _ => false,
    };

    private async Task TogglePipeMainAsync()
    {
        if (_selected is not DesignPipe pipe)
        {
            return;
        }

        if (pipe.IsMain)
        {
            // Demoting may leave no main — the "No main pipe" warning covers that.
            pipe.IsMain = false;
        }
        else
        {
            // Single-main invariant: demote the current main, promote this one.
            foreach (var other in _design.Pipes.Where(p => p.IsMain))
            {
                other.IsMain = false;
            }

            pipe.IsMain = true;
        }

        await SaveDesignAsync();
    }

    private async Task ResetSelectedOverridesAsync()
    {
        switch (_selected)
        {
            case DesignSprinkler s:
                s.FlowLitresPerHour = null;
                s.RadiusMetres = null;
                break;
            case DesignPipe p:
                p.DiameterMm = null;
                break;
            case DesignPoint pt:
                pt.RatedFlowLitresPerMinute = null;
                pt.RatedPressureBar = null;
                break;
        }

        await SaveDesignAsync();
    }

    // ---- Calculations (engine: Farm.Irrigation.Calculators) ----

    private sealed record LateralStats(
        int SprinklerCount, double FlowLitresPerMinute, double Velocity, double FrictionKpa);

    private readonly Dictionary<Guid, LateralStats> _lateralStats = new();

    private sealed record DesignResults(
        int EffectiveSprinklerCount,
        bool CountFromCanvas,
        double DemandFlowLitresPerMinute,
        double LateralFlowLitresPerMinute,
        bool LateralCountAssumed,
        int BusiestLateralSprinklers,
        double MainVelocity,
        double LateralVelocity,
        double FrictionLossBar,
        double RequiredPumpPressureBar,
        double CoverageRatio,
        double ApplicationRateMmPerHour,
        double RunTimeMinutes,
        int MaxSprinklers,
        double AvgSprinklerFlowLitresPerHour,
        double PumpFlowLitresPerMinute,
        double EffectiveSpacingMetres,
        bool SpacingFromCanvas);

    private const double LitresPerMinuteToM3PerHour = 0.06;
    private const double SprinklerHeadPressureBar = 2.0;
    private const int AssumedLateralCount = 3; // matches the demo layout when nothing is drawn

    // Connectivity tolerances (grid is 1 m): a lateral counts as plumbed into the
    // main within one cell; a sprinkler counts as sitting on its lateral within two.
    private const double LateralConnectToleranceM = 1.0;
    private const double SprinklerOnLateralToleranceM = 2.0;

    private readonly List<string> _warnings = new();
    private readonly HashSet<Guid> _disconnectedLateralIds = new();
    private readonly HashSet<Guid> _farSprinklerIds = new();

    private void Recompute()
    {
        _lateralStats.Clear();
        _warnings.Clear();
        _disconnectedLateralIds.Clear();
        _farSprinklerIds.Clear();
        var i = _design.Inputs;

        // Sprinklers placed on the canvas take precedence over the count input;
        // the input only applies while the layout has none (planning mode).
        var countFromCanvas = _design.Sprinklers.Count > 0;
        var effectiveCount = countFromCanvas ? _design.Sprinklers.Count : i.SprinklerCount;

        if (i.PumpFlowLitresPerMinute <= 0 || i.MainDiameterMm <= 0 || i.LateralDiameterMm <= 0
            || effectiveCount <= 0 || i.SprinklerFlowLitresPerHour <= 0
            || i.SprinklerSpacingMetres <= 0 || i.SprinklerRadiusMetres <= 0 || i.TargetDepthMm <= 0)
        {
            _results = null;
            return;
        }

        // Per-element overrides: null inherits the matching design input.
        double SprinklerFlowLhr(DesignSprinkler s) => s.FlowLitresPerHour ?? i.SprinklerFlowLitresPerHour;
        double PipeDiameterMm(DesignPipe p) => p.DiameterMm ?? (p.IsMain ? i.MainDiameterMm : i.LateralDiameterMm);

        var demandLmin = countFromCanvas
            ? _design.Sprinklers.Sum(SprinklerFlowLhr) / 60
            : ZoneDesignCalculators.DemandFlowLitresPerMinute(effectiveCount, i.SprinklerFlowLitresPerHour);
        var avgSprinklerFlowLhr = demandLmin * 60 / effectiveCount;

        var mainPipe = _design.Pipes.FirstOrDefault(p => p.IsMain);
        var mainDiameterMm = mainPipe is null ? i.MainDiameterMm : PipeDiameterMm(mainPipe);
        var mainVelocity = HydraulicsCalculators.VelocityMetresPerSecond(
            demandLmin * LitresPerMinuteToM3PerHour, mainDiameterMm);

        // Per-lateral hydraulics from the drawn layout: each placed sprinkler is
        // assigned to its nearest lateral, each lateral carries its own flow, and
        // lateral friction applies the Christiansen reduction (flow decreases at
        // every outlet). Results report the busiest lateral (worst path).
        var laterals = _design.Pipes.Where(p => !p.IsMain).ToList();
        var lateralCountAssumed = laterals.Count == 0;

        // Connectivity: geometric assignment isn't plumbing, so at least flag
        // laterals that don't touch the main and sprinklers far from their lateral.
        var connectedLaterals = mainPipe is null
            ? new List<DesignPipe>()
            : laterals.Where(l => l.DistanceToPipe(mainPipe) <= LateralConnectToleranceM).ToList();
        if (laterals.Count > 0)
        {
            foreach (var lateral in laterals.Where(l => !connectedLaterals.Contains(l)))
            {
                _disconnectedLateralIds.Add(lateral.Id);
            }

            if (mainPipe is null)
            {
                _warnings.Add("No main pipe — lateral connections can't be checked.");
            }
            else if (connectedLaterals.Count == 0)
            {
                _warnings.Add("None of the laterals connect to the main pipe — flows shown assume they do; check the layout.");
            }
            else if (_disconnectedLateralIds.Count > 0)
            {
                _warnings.Add($"{_disconnectedLateralIds.Count} lateral(s) are not connected to the main pipe — they carry no flow.");
            }
        }

        double lateralLmin;
        double lateralVelocity;
        var lateralFrictionKpa = 0.0;
        var busiestSprinklers = 0;

        if (lateralCountAssumed)
        {
            // No laterals drawn: assumed even split, no drawn length → no lateral friction.
            lateralLmin = demandLmin / AssumedLateralCount;
            lateralVelocity = HydraulicsCalculators.VelocityMetresPerSecond(
                lateralLmin * LitresPerMinuteToM3PerHour, i.LateralDiameterMm);
        }
        else if (countFromCanvas)
        {
            // Sprinklers route only to laterals plumbed into the main; if none are
            // connected, fall back to nearest-any so results never vanish (warned above).
            var routable = connectedLaterals.Count > 0 ? connectedLaterals : laterals;

            var assignedCounts = laterals.ToDictionary(p => p.Id, _ => 0);
            var assignedFlowsLhr = laterals.ToDictionary(p => p.Id, _ => 0.0);
            foreach (var sprinkler in _design.Sprinklers)
            {
                var nearest = routable.MinBy(p => p.DistanceToPoint(sprinkler.X, sprinkler.Y))!;
                assignedCounts[nearest.Id]++;
                assignedFlowsLhr[nearest.Id] += SprinklerFlowLhr(sprinkler);
                if (nearest.DistanceToPoint(sprinkler.X, sprinkler.Y) > SprinklerOnLateralToleranceM)
                {
                    _farSprinklerIds.Add(sprinkler.Id);
                }
            }

            if (_farSprinklerIds.Count > 0)
            {
                _warnings.Add($"{_farSprinklerIds.Count} sprinkler(s) are more than {F0(SprinklerOnLateralToleranceM)} m from their lateral.");
            }

            foreach (var lateral in laterals)
            {
                var assigned = assignedCounts[lateral.Id];
                var diameterMm = PipeDiameterMm(lateral);
                var flowLmin = assignedFlowsLhr[lateral.Id] / 60;
                var velocity = assigned > 0
                    ? HydraulicsCalculators.VelocityMetresPerSecond(flowLmin * LitresPerMinuteToM3PerHour, diameterMm)
                    : 0;
                var frictionForLateral = assigned > 0 && lateral.LengthMetres > 0
                    ? HydraulicsCalculators.LateralFrictionLoss(
                        flowLmin * LitresPerMinuteToM3PerHour, diameterMm,
                        lateral.LengthMetres, PipeRoughness.Upvc, assigned).PressureLossKpa
                    : 0;
                _lateralStats[lateral.Id] = new LateralStats(assigned, flowLmin, velocity, frictionForLateral);
            }

            var busiest = _lateralStats.Values.OrderByDescending(s => s.FlowLitresPerMinute).First();
            busiestSprinklers = busiest.SprinklerCount;
            lateralLmin = busiest.FlowLitresPerMinute;
            lateralVelocity = busiest.Velocity;
            lateralFrictionKpa = _lateralStats.Values.Max(s => s.FrictionKpa);
        }
        else
        {
            // Laterals drawn but no sprinklers placed: even split of the input count,
            // Christiansen F from the per-lateral outlet estimate, on the longest lateral.
            lateralLmin = demandLmin / laterals.Count;
            var outletsPerLateral = Math.Max(1, (int)Math.Round((double)effectiveCount / laterals.Count));
            var longestLateral = laterals.MaxBy(p => p.LengthMetres)!;
            var longestDiameterMm = PipeDiameterMm(longestLateral);
            lateralVelocity = HydraulicsCalculators.VelocityMetresPerSecond(
                lateralLmin * LitresPerMinuteToM3PerHour, longestDiameterMm);

            if (longestLateral.LengthMetres > 0)
            {
                lateralFrictionKpa = HydraulicsCalculators.LateralFrictionLoss(
                    lateralLmin * LitresPerMinuteToM3PerHour, longestDiameterMm,
                    longestLateral.LengthMetres, PipeRoughness.Upvc, outletsPerLateral).PressureLossKpa;
            }

            foreach (var lateral in laterals)
            {
                _lateralStats[lateral.Id] = new LateralStats(outletsPerLateral, lateralLmin, lateralVelocity, 0);
            }
        }

        var frictionKpa = lateralFrictionKpa;
        var mainLength = _design.Pipes.Where(p => p.IsMain).Sum(p => p.LengthMetres);
        if (mainLength > 0)
        {
            frictionKpa += HydraulicsCalculators.HazenWilliamsFrictionLoss(
                demandLmin * LitresPerMinuteToM3PerHour, mainDiameterMm, mainLength, PipeRoughness.Upvc).PressureLossKpa;
        }

        var frictionBar = frictionKpa / 100;

        // Application rate/runtime/coverage follow the layout: average effective
        // sprinkler flow, and (with ≥2 heads placed) the mean nearest-neighbour
        // spacing of the placed heads — equal to the grid spacing on a uniform
        // grid. Clamped to the 1 m grid resolution so stacked heads can't zero it.
        var spacingFromCanvas = countFromCanvas && _design.Sprinklers.Count >= 2;
        var effectiveSpacing = spacingFromCanvas
            ? Math.Max(1.0, ZoneDesignCalculators.MeanNearestNeighbourSpacing(
                _design.Sprinklers.Select(s => (s.X, s.Y)).ToList()))
            : i.SprinklerSpacingMetres;

        var applicationRate = ApplicationCalculators.SprinklerRateMmPerHour(
            avgSprinklerFlowLhr, effectiveSpacing, effectiveSpacing);

        // The max-sprinklers solver uses the placed pump's rating when one exists.
        var pump = _design.Points.FirstOrDefault(p => p.Kind == DesignPointKind.Pump);
        var pumpFlowLmin = pump?.RatedFlowLitresPerMinute ?? i.PumpFlowLitresPerMinute;

        _results = new DesignResults(
            effectiveCount,
            countFromCanvas,
            demandLmin,
            lateralLmin,
            lateralCountAssumed,
            busiestSprinklers,
            mainVelocity,
            lateralVelocity,
            frictionBar,
            frictionBar + SprinklerHeadPressureBar,
            ZoneDesignCalculators.CoverageRatio(
                countFromCanvas
                    ? _design.Sprinklers.Average(s => s.RadiusMetres ?? i.SprinklerRadiusMetres)
                    : i.SprinklerRadiusMetres,
                effectiveSpacing),
            applicationRate,
            ZoneDesignCalculators.RunTimeMinutesForDepth(i.TargetDepthMm, applicationRate),
            ZoneDesignCalculators.MaxSprinklersForPumpFlow(pumpFlowLmin, i.SprinklerFlowLitresPerHour),
            avgSprinklerFlowLhr,
            pumpFlowLmin,
            effectiveSpacing,
            spacingFromCanvas);
    }

    private string SolverLabel() => _solveMode switch
    {
        SolveMode.PumpFlow => "REQUIRED PUMP FLOW",
        SolveMode.MaxSprinklers => "MAX SPRINKLERS SUPPORTED",
        _ => "RECOMMENDED RUNTIME",
    };

    private string SolverValue()
    {
        if (_results is null)
        {
            return "—";
        }

        return _solveMode switch
        {
            SolveMode.PumpFlow => $"{F0(_results.DemandFlowLitresPerMinute)} L/min",
            SolveMode.MaxSprinklers => $"{_results.MaxSprinklers}",
            _ => $"{F0(_results.RunTimeMinutes)} min",
        };
    }

    private string SolverNote()
    {
        if (_results is null)
        {
            return "Enter valid design inputs";
        }

        var i = _design.Inputs;
        return _solveMode switch
        {
            SolveMode.PumpFlow => $"{_results.EffectiveSprinklerCount} sprinklers{(_results.CountFromCanvas ? " placed on canvas" : "")} × {F0(_results.AvgSprinklerFlowLitresPerHour)} L/hr",
            SolveMode.MaxSprinklers => $"at {F0(_results.PumpFlowLitresPerMinute)} L/min pump flow, {F0(i.SprinklerFlowLitresPerHour)} L/hr each",
            _ => $"to deliver {F0(i.TargetDepthMm)}mm at {F1(_results.ApplicationRateMmPerHour)} mm/hr",
        };
    }

    private static string VelocityNote(double velocity) =>
        velocity <= 1.5 ? "Within recommended range" : "Above ~1.5 m/s guideline";

    private static string CoverageNote(double ratio)
    {
        // Note: relational switch patterns ("< 0.9 =>") break the Razor parser
        // inside @code blocks (misread as a tag) — hence plain ifs here.
        if (ratio < 0.9)
        {
            return "Gaps in coverage — increase radius or reduce spacing";
        }

        if (ratio > 1.3)
        {
            return "Heavy overlap — spacing could be wider";
        }

        return "Good coverage";
    }

    private static string F0(double value) => value.ToString("0", CultureInfo.InvariantCulture);
    private static string F1(double value) => value.ToString("0.0", CultureInfo.InvariantCulture);
    private static string F2(double value) => value.ToString("0.00", CultureInfo.InvariantCulture);
}
