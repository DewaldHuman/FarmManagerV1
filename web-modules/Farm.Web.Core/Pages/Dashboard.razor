@page "/"
@layout AppShellLayout
@attribute [Authorize]
@inject IStringLocalizer<AppStrings> Localizer

<div class="page-header">
    <div>
        <div class="app-shell__eyebrow">@Localizer["Dashboard_Eyebrow"]</div>
        <h1 class="app-shell__title">@Localizer["Dashboard_Title"]</h1>
    </div>
    @if (_canToggleView)
    {
        <div class="view-toggle">
            <button class="view-toggle__btn @(ViewMode == DashboardView.Owner ? "view-toggle__btn--active" : "")"
                    @onclick="() => SetView(DashboardView.Owner)">
                @Localizer["Dashboard_OwnerView"]
            </button>
            <button class="view-toggle__btn @(ViewMode == DashboardView.Worker ? "view-toggle__btn--active" : "")"
                    @onclick="() => SetView(DashboardView.Worker)">
                @Localizer["Dashboard_WorkerView"]
            </button>
        </div>
    }
</div>
<div class="page-subtitle">@Localizer["Dashboard_Subtitle"]</div>

@if (ViewMode == DashboardView.Owner)
{
    <div class="stat-grid">
        @foreach (var stat in _stats)
        {
            <div class="stat-card stat-card--@stat.Tone">
                <div class="stat-card__value">@stat.Value</div>
                <div class="stat-card__label">@stat.Label</div>
            </div>
        }
    </div>

    <h3 class="section-heading">@Localizer["Dashboard_RecentActivity"]</h3>
    <div class="activity-list">
        @foreach (var item in _activity)
        {
            <div class="activity-row">
                <div>@item.Text</div>
                <div class="activity-row__time">@item.Time</div>
            </div>
        }
    </div>
}
else
{
    <h3 class="section-heading section-heading--lg">@Localizer["Dashboard_WhatNeedsDoing"]</h3>
    <div class="today-list">
        @foreach (var task in _todayTasks)
        {
            <div class="today-card today-card--@task.Tone">
                <div>
                    <div class="today-card__name">@task.Name</div>
                    <div class="today-card__crop">@task.Crop</div>
                </div>
                <div class="today-card__actions">
                    <div class="pill pill-@task.Tone">@task.Note</div>
                    <button class="btn btn-primary">@Localizer["Dashboard_Run"]</button>
                </div>
            </div>
        }
    </div>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private enum DashboardView { Owner, Worker }

    private DashboardView ViewMode = DashboardView.Owner;
    private bool _canToggleView;

    private void SetView(DashboardView mode) => ViewMode = mode;

    private sealed record Stat(string Label, string Value, string Tone);
    private sealed record Activity(string Text, string Time);
    private sealed record TodayTask(string Name, string Crop, string Note, string Tone);

    // Mock/demo data — replace with real data-bound content once Core: Farm/Zone
    // registry + Irrigation data model land (plan.md Phase 1). Localized in the
    // meantime since it renders as real UI text today.
    private List<Stat> _stats = new();
    private List<Activity> _activity = new();
    private List<TodayTask> _todayTasks = new();

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask is not null)
        {
            var authState = await AuthStateTask;
            var roleClaim = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;

            if (string.Equals(roleClaim, "worker", StringComparison.OrdinalIgnoreCase))
            {
                ViewMode = DashboardView.Worker;
                _canToggleView = false;
            }
            else
            {
                // owner or manager (or unrecognized/missing claim — fail toward the
                // fuller Owner view rather than silently locking out an authenticated user)
                ViewMode = DashboardView.Owner;
                _canToggleView = true;
            }
        }

        _stats = new List<Stat>
        {
            new(Localizer["Dashboard_Stat_ActiveZones"], "18", "neutral"),
            new(Localizer["Dashboard_Stat_DueToday"], "3", "due"),
            new(Localizer["Dashboard_Stat_Overdue"], "1", "overdue"),
            new(Localizer["Dashboard_Stat_RunsLoggedThisWeek"], "22", "neutral"),
        };

        _activity = new List<Activity>
        {
            new(Localizer["Dashboard_Activity_1"], "6:12am"),
            new(Localizer["Dashboard_Activity_2"], Localizer["Dashboard_Time_Yesterday"]),
            new(Localizer["Dashboard_Activity_3"], Localizer["Dashboard_Time_2DaysAgo"]),
            new(Localizer["Dashboard_Activity_4"], Localizer["Dashboard_Time_2DaysAgo"]),
        };

        _todayTasks = new List<TodayTask>
        {
            new(Localizer["Dashboard_Task_WestPasture_Name"], Localizer["Dashboard_Task_WestPasture_Crop"], Localizer["Dashboard_Task_WestPasture_Note"], "overdue"),
            new(Localizer["Dashboard_Task_SouthField3_Name"], Localizer["Dashboard_Task_Alfalfa"], Localizer["Dashboard_Task_DueToday"], "due"),
            new(Localizer["Dashboard_Task_SouthField4_Name"], Localizer["Dashboard_Task_Alfalfa"], Localizer["Dashboard_Task_DueToday"], "due"),
        };
    }
}
