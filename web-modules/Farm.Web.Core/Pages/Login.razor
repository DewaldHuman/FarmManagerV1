@page "/login"
@layout BlankLayout
@inject IStringLocalizer<AppStrings> Localizer

<div class="login-page">
    <div class="login-card">
        <div class="login-card__brand">
            <div class="login-card__eyebrow">@Localizer["Login_Eyebrow"]</div>
            <h2 class="login-card__headline">@Localizer["Login_Headline"]</h2>
            <p class="login-card__copy">@Localizer["Login_Copy"]</p>
        </div>
        <div class="login-card__form">
            <h1>@Localizer["Login_SignIn"]</h1>

            <label class="form-label" for="login-username">@Localizer["Login_EmailOrUsername"]</label>
            <input id="login-username" class="form-input" @bind="Username" @bind:event="oninput" />

            <label class="form-label" for="login-password">@Localizer["Login_Password"]</label>
            <input id="login-password" type="password" class="form-input" @bind="Password" @bind:event="oninput" />

            <button class="btn btn-primary login-card__submit" @onclick="HandleSignIn">@Localizer["Login_SignIn"]</button>

            <div class="login-card__helper">@((MarkupString)Localizer["Login_Helper"].Value)</div>
        </div>
    </div>
</div>

@code {
    private string Username = string.Empty;
    private string Password = string.Empty;

    private void HandleSignIn()
    {
        // Wired up once Core: Users + Auth lands (plan.md).
    }
}
