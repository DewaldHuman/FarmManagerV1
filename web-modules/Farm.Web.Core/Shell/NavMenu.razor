@inject NavigationManager Nav
@inject IStringLocalizer<AppStrings> Localizer

<nav class="app-shell__nav">
    <div class="app-shell__farm-name">@Localizer["NavMenu_FarmName"]</div>

    @foreach (var item in _navItems)
    {
        <div>
            @if (item.Href is not null)
            {
                <a href="@item.Href"
                   class="app-shell__nav-item @(IsActive(item.Href, matchPrefix: true) ? "app-shell__nav-item--active" : "app-shell__nav-item--inactive")">
                    <span>@item.Icon</span>@item.Label
                </a>
            }
            else
            {
                <div class="app-shell__nav-item app-shell__nav-item--soon">
                    <span>@item.Icon</span>@item.Label
                    <span class="app-shell__soon-tag">@Localizer["NavMenu_Soon"]</span>
                </div>
            }

            @if (item.SubItems is { Count: > 0 })
            {
                <div class="app-shell__subnav">
                    @foreach (var sub in item.SubItems)
                    {
                        <a href="@sub.Href"
                           class="app-shell__subnav-item @(IsActive(sub.Href, matchPrefix: false) ? "app-shell__subnav-item--active" : "")">
                            @sub.Label
                        </a>
                    }
                </div>
            }
        </div>
    }
</nav>

@code {
    private sealed record SubNavItem(string Label, string Href);

    private sealed record NavItem(string Icon, string Label, string? Href, IReadOnlyList<SubNavItem>? SubItems = null);

    private List<NavItem> _navItems = new();

    protected override void OnInitialized()
    {
        _navItems = new List<NavItem>
        {
            new("💧", Localizer["NavMenu_Irrigation"], "/irrigation/zones", new List<SubNavItem>
            {
                new(Localizer["NavMenu_Sub_Zones"], "/irrigation/zones"),
                new(Localizer["NavMenu_Sub_RunCalculator"], "/irrigation/run-calculator"),
                new(Localizer["NavMenu_Sub_ZoneDesigns"], "/irrigation/zone-designs"),
                new(Localizer["NavMenu_Sub_History"], "/irrigation/history"),
            }),
            new("🔧", Localizer["NavMenu_Assets"], null),
            new("🌱", Localizer["NavMenu_Crops"], null),
            new("✅", Localizer["NavMenu_Tasks"], null),
            new("💰", Localizer["NavMenu_Finance"], null),
            new("📊", Localizer["NavMenu_Reporting"], null),
        };
    }

    private bool IsActive(string href, bool matchPrefix)
    {
        var relative = "/" + Nav.ToBaseRelativePath(Nav.Uri).TrimEnd('/');
        var target = href.TrimEnd('/');

        return matchPrefix
            ? relative.StartsWith(target, StringComparison.OrdinalIgnoreCase)
            : relative.Equals(target, StringComparison.OrdinalIgnoreCase);
    }
}
