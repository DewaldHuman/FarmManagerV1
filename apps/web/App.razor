<Router AppAssembly="@typeof(App).Assembly" AdditionalAssemblies="new[] { typeof(Farm.Web.Core.Shell.AppShellLayout).Assembly }">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(Farm.Web.Core.Shell.AppShellLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>Not found</PageTitle>
        <LayoutView Layout="@typeof(Farm.Web.Core.Shell.AppShellLayout)">
            <p role="alert">Sorry, there's nothing at this address.</p>
        </LayoutView>
    </NotFound>
</Router>
