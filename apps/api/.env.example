# Copy to .env and fill in real values for your environment.
DATABASE_URL=postgresql+psycopg://farm:farm@localhost:5432/farm_platform

# MUST be overridden with a long random secret in any real deployment
# (staging/production/cloud). The default in config.py is a placeholder
# ONLY safe for local dev on a trusted LAN.
JWT_SECRET=change_me_too

# 720 = 12 hours. Matches the LAN/low-risk deployment model — no refresh
# tokens in v1, users simply re-login after expiry.
JWT_EXPIRY_MINUTES=720
